{
  "productName": "Noviforma",
  "version": "0.1.0",
  "identifier": "com.noviforma.app",
  "build": {
    "devUrl": "http://localhost:5173",
    "frontendDist": "../apps/ui-react/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Noviforma",
        "width": 1600,
        "height": 1000,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "transparent": true,
        "devtools": true,
        "additionalBrowserArgs": "--enable-features=Vulkan,UseSkiaRenderer --enable-unsafe-webgpu"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../assets/icons/windows11/Square44x44Logo.targetsize-256.png",
      "../assets/icons/ios/1024.png",
      "../assets/icons/android/android-launchericon-512-512.png"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  }
}
